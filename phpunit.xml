    <testsuite name="Integration">
      <directory suffix="Test.php">./tests/Integration</directory>
    </testsuite>
    <testsuite name="Acceptance">
      <directory suffix="Test.php">./tests/Acceptance</directory>
    </testsuite>
  </testsuites>
</phpunit>
